{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "entraTenantId": {
      "value": "${ENTRA_TENANT_ID}"
    },
    "gatewayAudience": {
      "value": "${GATEWAY_APP_ID_URI}"
    },
    "allowedClientIds": {
      "value": "${ALLOWED_CLIENT_IDS}"
    },
    "modelDeploymentName": {
      "value": "${FOUNDRY_MODEL_DEPLOYMENT_NAME}"
    },
    "modelName": {
      "value": "${FOUNDRY_MODEL_NAME}"
    },
    "modelVersion": {
      "value": "${FOUNDRY_MODEL_VERSION}"
    },
    "modelSkuName": {
      "value": "${FOUNDRY_MODEL_SKU_NAME}"
    },
    "modelCapacity": {
      "value": "${FOUNDRY_MODEL_CAPACITY}"
    }
  }
}
